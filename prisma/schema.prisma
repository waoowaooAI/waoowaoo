generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 用户表
model User {
  id          String   @id @default(cuid())
  name        String   @unique
  email       String?
  password    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt() @map("updated_at")

  projects    Project[]
  preferences UserPreference?
  balance     UserBalance?

  @@map("ivm_user")
}

/// 用户偏好设置
model UserPreference {
  id                String  @id @default(cuid())
  userId            String  @unique @map("user_id")
  analysisModel     String? @map("analysis_model")
  imageModel        String? @map("image_model")
  videoModel        String? @map("video_model")
  characterModel    String? @map("character_model")
  locationModel     String? @map("location_model")
  storyboardModel   String? @map("storyboard_model")
  editModel         String? @map("edit_model")
  lipSyncModel      String? @map("lip_sync_model")
  imageResolution   String? @map("image_resolution")
  apiKeys           String? @map("api_keys") @db.Text
  customModels      String? @map("custom_models") @db.Text
  customProviders   String? @map("custom_providers") @db.Text
  capabilityDefaults String? @map("capability_defaults") @db.Text
  billingMode       String  @default("OFF") @map("billing_mode")

  user User @relation(fields: [userId], references: [id])

  @@map("ivm_user_preference")
}

/// 用户余额
model UserBalance {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  balance      Decimal  @default(0) @db.Decimal(18, 6)
  frozenAmount Decimal  @default(0) @map("frozen_amount") @db.Decimal(18, 6)
  totalSpent   Decimal  @default(0) @map("total_spent") @db.Decimal(18, 6)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt() @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("ivm_user_balance")
}

/// 余额冻结记录
model BalanceFreeze {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  amount          Decimal  @db.Decimal(18, 6)
  status          String   @default("pending")
  taskId          String?  @map("task_id")
  requestId       String?  @map("request_id")
  source          String?
  metadata        String?  @db.Text
  idempotencyKey  String?  @unique @map("idempotency_key")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("ivm_balance_freeze")
}

/// 余额交易流水
model BalanceTransaction {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  type         String
  amount       Decimal  @db.Decimal(18, 6)
  balanceAfter Decimal  @map("balance_after") @db.Decimal(18, 6)
  description  String?
  relatedId    String?  @map("related_id")
  freezeId     String?  @map("freeze_id")
  operatorId   String?  @map("operator_id")
  externalOrderId String? @map("external_order_id")
  idempotencyKey String?  @map("idempotency_key")
  projectId    String?  @map("project_id")
  episodeId    String?  @map("episode_id")
  taskType     String?  @map("task_type")
  billingMeta  Json?    @map("billing_meta") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("ivm_balance_transaction")
}

/// 项目表
model Project {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.Text
  userId          String   @map("user_id")
  segmentDuration Int      @default(5) @map("segment_duration")
  episodeDuration Int      @default(60) @map("episode_duration")
  totalDuration   Int      @default(600) @map("total_duration")
  episodeCount    Int      @default(10) @map("episode_count")
  analysisModel   String?  @map("analysis_model")
  imageModel      String?  @map("image_model")
  videoModel      String?  @map("video_model")
  characterModel  String?  @map("character_model")
  locationModel   String?  @map("location_model")
  storyboardModel String?  @map("storyboard_model")
  editModel       String?  @map("edit_model")
  artStyle        String   @default("cinematic") @map("art_style")
  videoRatio      String   @default("9:16") @map("video_ratio")
  videoResolution String?  @map("video_resolution")
  capabilityOverrides String? @map("capability_overrides") @db.Text
  novelText       String?  @map("novel_text") @db.Text
  globalContext   String?  @map("global_context") @db.Text
  lastAccessedAt  DateTime? @map("last_accessed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt() @map("updated_at")

  user       User       @relation(fields: [userId], references: [id])
  episodes   Episode[]
  characters Character[]
  locations  Location[]
  props      Prop[]
  tasks      Task[]

  @@map("ivm_project")
}

/// 剧集表
model Episode {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  episodeIndex Int      @map("episode_index")
  name         String?
  novelText    String?  @map("novel_text") @db.Text
  context      String?  @db.Text
  audioUrl     String?  @map("audio_url")
  srtContent   String?  @map("srt_content") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt() @map("updated_at")

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  segments   Segment[]
  voiceLines VoiceLine[]

  @@unique([projectId, episodeIndex])
  @@map("ivm_episode")
}

/// 片段表
model Segment {
  id           String   @id @default(cuid())
  episodeId    String   @map("episode_id")
  segmentIndex Int      @map("segment_index")
  summary      String?  @db.Text
  content      String?  @db.Text
  startTime    Float    @map("start_time")
  endTime      Float    @map("end_time")
  location     String?
  characters   Json?    @db.JsonB
  props        Json?    @db.JsonB
  screenplay   String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt() @map("updated_at")

  episode          Episode           @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  storyboardEntries StoryboardEntry[]
  segmentVideo     SegmentVideo?

  @@unique([episodeId, segmentIndex])
  @@map("ivm_segment")
}

/// 角色表
model Character {
  id               String   @id @default(cuid())
  projectId        String   @map("project_id")
  name             String
  aliases          String[] @default([])
  profileData      Json?    @map("profile_data") @db.JsonB
  introduction     String?  @db.Text
  voicePresetId    String?  @map("voice_preset_id")
  profileConfirmed Boolean  @default(false) @map("profile_confirmed")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt() @map("updated_at")

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  appearances    CharacterAppearance[]
  characterViews CharacterView[]

  @@unique([projectId, name])
  @@map("ivm_character")
}

/// 角色外观图
model CharacterAppearance {
  id              String   @id @default(cuid())
  characterId     String   @map("character_id")
  appearanceIndex Int      @map("appearance_index")
  description     String?  @db.Text
  imageUrl        String?  @map("image_url")
  imagePrompt     String?  @map("image_prompt") @db.Text
  previousImageUrl String? @map("previous_image_url")
  createdAt       DateTime @default(now()) @map("created_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, appearanceIndex])
  @@map("ivm_character_appearance")
}

/// 角色视图
model CharacterView {
  id          String   @id @default(cuid())
  characterId String   @map("character_id")
  viewType    String   @map("view_type")
  imageUrl    String?  @map("image_url")
  imagePrompt String?  @map("image_prompt") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt() @map("updated_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, viewType])
  @@map("ivm_character_view")
}

/// 场景表
model Location {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  summary     String?  @db.Text
  atmosphere  String?
  timeOfDay   String?  @map("time_of_day")
  lighting    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt() @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  locationImages LocationImage[]
  locationViews  LocationView[]

  @@unique([projectId, name])
  @@map("ivm_location")
}

/// 场景图片
model LocationImage {
  id          String   @id @default(cuid())
  locationId  String   @map("location_id")
  imageIndex  Int      @map("image_index")
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  isSelected  Boolean  @default(false) @map("is_selected")
  createdAt   DateTime @default(now()) @map("created_at")

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, imageIndex])
  @@map("ivm_location_image")
}

/// 场景多视图
model LocationView {
  id          String   @id @default(cuid())
  locationId  String   @map("location_id")
  viewType    String   @map("view_type")
  imageUrl    String?  @map("image_url")
  imagePrompt String?  @map("image_prompt") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt() @map("updated_at")

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, viewType])
  @@map("ivm_location_view")
}

/// 道具表
model Prop {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  name         String
  description  String?  @db.Text
  imageUrl     String?  @map("image_url")
  imagePrompt  String?  @map("image_prompt") @db.Text
  significance String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt() @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@map("ivm_prop")
}

/// 分镜条目
model StoryboardEntry {
  id              String   @id @default(cuid())
  segmentId       String   @map("segment_id")
  entryIndex      Int      @map("entry_index")
  startTime       Float    @map("start_time")
  endTime         Float    @map("end_time")
  description     String   @db.Text
  characterRefs   Json?    @map("character_refs") @db.JsonB
  soundEffect     String?  @map("sound_effect")
  dialogue        String?  @db.Text
  dialogueSpeaker String?  @map("dialogue_speaker")
  dialogueTone    String?  @map("dialogue_tone")
  imageUrl        String?  @map("image_url")
  imagePrompt     String?  @map("image_prompt") @db.Text
  previousImageUrl String? @map("previous_image_url")
  shotType        String?  @map("shot_type")
  cameraMove      String?  @map("camera_move")
  photographyNotes String? @map("photography_notes") @db.Text
  actingNotes     String?  @map("acting_notes") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt() @map("updated_at")

  segment Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([segmentId, entryIndex])
  @@map("ivm_storyboard_entry")
}

/// 语音台词
model VoiceLine {
  id              String   @id @default(cuid())
  episodeId       String   @map("episode_id")
  lineIndex       Int      @map("line_index")
  speaker         String
  content         String   @db.Text
  voicePresetId   String?  @map("voice_preset_id")
  audioUrl        String?  @map("audio_url")
  emotionPrompt   String?  @map("emotion_prompt")
  emotionStrength Float?   @map("emotion_strength")
  matchedEntryId  String?  @map("matched_entry_id")
  createdAt       DateTime @default(now()) @map("created_at")

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([episodeId, lineIndex])
  @@map("ivm_voice_line")
}

/// 片段视频
model SegmentVideo {
  id          String   @id @default(cuid())
  segmentId   String   @unique @map("segment_id")
  videoUrl    String?  @map("video_url")
  videoPrompt String?  @map("video_prompt") @db.Text
  modelKey    String?  @map("model_key")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt() @map("updated_at")

  segment Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@map("ivm_segment_video")
}

/// 时间轴编辑项目
model TimelineProject {
  id           String   @id @default(cuid())
  projectId    String   @unique @map("project_id")
  projectData  Json?    @map("project_data") @db.JsonB
  renderStatus String?  @map("render_status")
  outputUrl    String?  @map("output_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt() @map("updated_at")

  @@map("ivm_timeline_project")
}

/// 媒体对象
model MediaObject {
  id         String   @id @default(cuid())
  publicId   String   @unique @map("public_id")
  storageKey String   @unique @map("storage_key")
  sha256     String?
  mimeType   String?  @map("mime_type")
  sizeBytes  Int?     @map("size_bytes")
  width      Int?
  height     Int?
  durationMs Int?     @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("ivm_media_object")
}

/// 任务表
model Task {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  projectId    String?   @map("project_id")
  episodeId    String?   @map("episode_id")
  type         String
  targetType   String?   @map("target_type")
  targetId     String?   @map("target_id")
  status       String    @default("queued")
  priority     Int       @default(0)
  progress     Float?    @default(0)
  attempt      Int       @default(0)
  maxAttempts  Int       @default(3) @map("max_attempts")
  enqueueAttempts Int    @default(0) @map("enqueue_attempts")
  dedupeKey    String?   @unique @map("dedupe_key")
  externalId   String?   @map("external_id")
  payload      Json?     @db.JsonB
  result       Json?     @db.JsonB
  errorCode    String?   @map("error_code")
  errorMessage String?   @map("error_message") @db.Text
  lastEnqueueError String? @map("last_enqueue_error") @db.Text
  billingInfo  Json?     @map("billing_info") @db.JsonB
  createdAt    DateTime  @default(now()) @map("created_at")
  enqueuedAt   DateTime? @map("enqueued_at")
  queuedAt     DateTime  @default(now()) @map("queued_at")
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  heartbeatAt  DateTime? @map("heartbeat_at")
  updatedAt    DateTime  @updatedAt() @map("updated_at")

  project Project? @relation(fields: [projectId], references: [id])

  @@map("ivm_task")
}

/// 任务事件
model TaskEvent {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  projectId String?  @map("project_id")
  eventType String   @map("event_type")
  payload   Json?    @db.JsonB
  seq       Int
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([taskId, seq])
  @@map("ivm_task_event")
}

/// 使用成本记录
model UsageCost {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  projectId String?  @map("project_id")
  apiType   String   @map("api_type")
  model     String
  action    String
  quantity  Float
  unit      String
  cost      Decimal  @db.Decimal(18, 6)
  metadata  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ivm_usage_cost")
}

/// 熔断器状态
model CircuitBreakerState {
  id            String   @id @default(cuid())
  modelKey      String   @unique @map("model_key")
  state         String   @default("closed")
  failureCount  Int      @default(0) @map("failure_count")
  lastFailureAt DateTime? @map("last_failure_at")
  openedAt      DateTime? @map("opened_at")
  cooldownUntil DateTime? @map("cooldown_until")
  updatedAt     DateTime @updatedAt() @map("updated_at")

  @@map("ivm_circuit_breaker_state")
}

/// 缓存表
model CacheEntry {
  id        String   @id @default(cuid())
  cacheKey  String   @unique @map("cache_key")
  value     Json     @db.JsonB
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("ivm_cache_entry")
}

/// 工作流执行记录
model GraphRun {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  projectId    String    @map("project_id")
  workflowType String    @map("workflow_type")
  taskType     String?   @map("task_type")
  taskId       String?   @map("task_id")
  status       String    @default("running")
  input        Json?     @db.JsonB
  output       Json?     @db.JsonB
  errorCode    String?   @map("error_code")
  createdAt    DateTime  @default(now()) @map("created_at")
  finishedAt   DateTime? @map("finished_at")

  steps       GraphStep[]
  checkpoints GraphCheckpoint[]

  @@map("ivm_graph_run")
}

/// 工作流步骤
model GraphStep {
  id             String   @id @default(cuid())
  runId          String   @map("run_id")
  stepKey        String   @map("step_key")
  stepTitle      String?  @map("step_title")
  stepIndex      Int?     @map("step_index")
  stepTotal      Int?     @map("step_total")
  status         String   @default("pending")
  currentAttempt Int      @default(0) @map("current_attempt")
  createdAt      DateTime @default(now()) @map("created_at")

  run      GraphRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  attempts GraphStepAttempt[]

  @@unique([runId, stepKey])
  @@map("ivm_graph_step")
}

/// 工作流步骤尝试
model GraphStepAttempt {
  id              String   @id @default(cuid())
  runId           String   @map("run_id")
  stepKey         String   @map("step_key")
  attempt         Int
  status          String   @default("running")
  provider        String?
  modelKey        String?  @map("model_key")
  outputText      String?  @map("output_text") @db.Text
  outputReasoning String?  @map("output_reasoning") @db.Text
  usageJson       Json?    @map("usage_json") @db.JsonB
  createdAt       DateTime @default(now()) @map("created_at")

  step GraphStep @relation(fields: [runId, stepKey], references: [runId, stepKey], onDelete: Cascade)

  @@unique([runId, stepKey, attempt])
  @@map("ivm_graph_step_attempt")
}

/// 工作流检查点
model GraphCheckpoint {
  id        String   @id @default(cuid())
  runId     String   @map("run_id")
  nodeKey   String   @map("node_key")
  version   Int
  stateJson Json     @map("state_json") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  run GraphRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, nodeKey, version])
  @@map("ivm_graph_checkpoint")
}
